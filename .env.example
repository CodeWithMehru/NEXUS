# ============================================================================
# NEXUS AI — Environment Variables
# Copy this file to `.env.local` and fill in real values.
# ============================================================================

# ---- Supabase ----------------------------------------------------------------
NEXT_PUBLIC_SUPABASE_URL=https://YOUR-PROJECT-REF.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=YOUR_SUPABASE_ANON_KEY

# Server-side only. Used by API routes for privileged inserts.
SUPABASE_SERVICE_ROLE_KEY=YOUR_SUPABASE_SERVICE_ROLE_KEY

# ---- Groq --------------------------------------------------------------------
# Get your key from https://console.groq.com/keys
GROQ_API_KEY=gsk_xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx

# Optional model override (default = llama-3.3-70b-versatile, JSON mode enforced)
GROQ_MODEL=llama-3.3-70b-versatile

# ---- Tavily (live web grounding) --------------------------------------------
# OPTIONAL. When set, Nexus Mode grounds its market signals in live web results
# and labels the report "Grounded by live web search". Without it, the app
# degrades gracefully to honest AI-inferred signals.
# Free key (1,000 searches/month): https://tavily.com
TAVILY_API_KEY=tvly-xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx
